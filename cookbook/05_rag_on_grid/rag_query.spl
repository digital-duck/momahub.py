-- Recipe 05: RAG query dispatched to the grid
PROMPT rag_answer
WITH BUDGET 2000 tokens
USING MODEL 'llama3'
ON GRID

SELECT
    SYSTEM_ROLE('You are a helpful assistant that answers questions based on provided context.'),
    RAG_QUERY('What are the key benefits of hub-and-spoke inference?') AS context

GENERATE
    answer('Using only the provided context, answer: What are the key benefits of hub-and-spoke inference?')
WITH OUTPUT BUDGET 1000 tokens;
